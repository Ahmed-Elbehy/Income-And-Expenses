{
  "name": "daily-income-expense-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "A responsive daily income and expense tracker with local Google font, Tailwind CSS, Font Awesome, and SweetAlert2.",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.5"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.0",
    "sweetalert2": "^11.7.5"
  }
}
